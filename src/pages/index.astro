---
import BlogLayout from "../layouts/BlogLayout.astro";
import PostCard from "../components/PostCard.astro";
import logoSrc from "../assets/logo.jpeg";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BlogLayout title="Inicio">
  <section class="hero">
    <div class="container">
      <img src={logoSrc.src} alt="ARMILLARY" class="hero-logo" width="72" height="72" />
      <h1 class="hero-name">ARM<em>ILLARY</em></h1>
      <p class="hero-sub">Geospatial Analysis · Data Science · GIS Development</p>
      <div class="hero-dots">
        <span class="hero-dot">Python</span>
        <span class="hero-dot">GIS</span>
        <span class="hero-dot">Data Science</span>
        <span class="hero-dot">Geospatial</span>
        <span class="hero-dot">Open Source</span>
      </div>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">
      <div class="posts-section-title">Publicaciones</div>
      {sortedPosts.length > 0 ? (
        sortedPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            url={`/armillary-blog/blog/${post.slug}/`}
            tags={post.data.tags}
          />
        ))
      ) : (
        <div class="empty-state">
          <h2>Próximamente</h2>
          <p>Estamos preparando contenido nuevo.</p>
        </div>
      )}
    </div>
  </section>
</BlogLayout>