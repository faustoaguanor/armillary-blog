---
import BlogLayout from "../layouts/BlogLayout.astro";
import PostCard from "../components/PostCard.astro";
import logoSrc from "../assets/logo.jpeg";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BlogLayout title="Inicio">
  <section class="hero">
    <div class="container">
      <img src={logoSrc.src} alt="ARMILLARY" class="hero-logo" width="140" height="140" />
      <h1 class="hero-name">ARMILLARY</h1>
      <p class="hero-sub">GEOSPATIAL ANALYSIS  ·  DATA SCIENCE  ·  GIS DEVELOPMENT</p>
<div class="hero-dots">
          <a class="hero-dot" href="/armillary-blog/tag/geospatial-analysis/">🗺️ Geospatial Analysis</a>
          <a class="hero-dot" href="/armillary-blog/tag/data-science/">📊 Data Science</a>
          <a class="hero-dot" href="/armillary-blog/tag/gis-programming/">💻 GIS Programming</a>
          <a class="hero-dot" href="/armillary-blog/tag/geospatial-databases/">🗄️ Geospatial Databases</a>
          <a class="hero-dot" href="/armillary-blog/tag/gis-desktop/">🖥️ GIS Desktop</a>
          <a class="hero-dot" href="/armillary-blog/tag/gis-servers/">🌐 GIS Servers</a>
          <a class="hero-dot" href="/armillary-blog/tag/data-quality/">✅ Data Quality</a>
        </div>
    </div>
  </section>

  <section class="posts-section">
    <div class="container">
      <div class="posts-section-title">Publicaciones</div>
      {sortedPosts.length > 0 ? (
        sortedPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            url={`/armillary-blog/blog/${post.slug}/`}
            tags={post.data.tags}
          />
        ))
      ) : (
        <div class="empty-state">
          <h2>Próximamente</h2>
          <p>Estamos preparando contenido nuevo.</p>
        </div>
      )}
    </div>
  </section>
</BlogLayout>